{
    "openapi": "3.0.3",
    "info": {
      "title": "Geligeli API",
      "version": "1.0.0",
      "description": "视频、点赞、收藏、评论、关注相关接口"
    },
    "servers": [
      {
        "url": "http://localhost:8080"
      }
    ],
    "tags": [
      { "name": "Video" },
      { "name": "Comment" },
      { "name": "Follow" }
    ],
    "components": {
      "securitySchemes": {
        "Authorization": {
          "type": "http",
          "scheme": "bearer",
          "bearerFormat": "JWT",
          "description": "在请求头中传入: Authorization: Bearer <token>",
          "example": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIyMDQyMTM1NzQyMTM3NTY5MjgwIiwiaWF0IjoxNzc2MTQ2Mzk1LCJleHAiOjE4MDYxNDYzOTV9.ixjMCe_sGLIDQC0r9JFV0J_GMUJIx7pfG78pdXlOq3s"
        }
      },
      "schemas": {
        "VideoActionRequest": {
          "type": "object",
          "required": ["userId", "videoId"],
          "properties": {
            "userId": { "type": "integer", "format": "int64", "example": 2042135742137569280 },
            "videoId": { "type": "integer", "format": "int64", "example": 2043382974715662336 }
          }
        },
        "CancelVideoActionRequest": {
          "type": "object",
          "required": ["id", "videoId"],
          "properties": {
            "id": { "type": "integer", "format": "int64", "example": 2044000000000000001 },
            "videoId": { "type": "integer", "format": "int64", "example": 2043382974715662336 }
          }
        },
        "CreateCommentRequest": {
          "type": "object",
          "required": ["content", "userId", "videoId"],
          "properties": {
            "content": { "type": "string", "example": "这视频不错" },
            "userId": { "type": "integer", "format": "int64", "example": 2042135742137569280 },
            "videoId": { "type": "integer", "format": "int64", "example": 2043382974715662336 },
            "parentCommentId": { "type": "integer", "format": "int64", "nullable": true, "example": null }
          }
        },
        "FollowRequest": {
          "type": "object",
          "required": ["userId", "creatorId"],
          "properties": {
            "userId": { "type": "integer", "format": "int64", "example": 2042135742137569280 },
            "creatorId": { "type": "integer", "format": "int64", "example": 2044049530885570560 }
          }
        }
      }
    },
    "security": [
      {
        "Authorization": []
      }
    ],
    "paths": {
      "/api/video/detail": {
        "post": {
          "tags": ["Video"],
          "summary": "视频详情",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/like": {
        "post": {
          "tags": ["Video"],
          "summary": "点赞",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/cancel/like": {
        "post": {
          "tags": ["Video"],
          "summary": "取消点赞",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancelVideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/favorite": {
        "post": {
          "tags": ["Video"],
          "summary": "收藏",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/cancel/favorite": {
        "post": {
          "tags": ["Video"],
          "summary": "取消收藏",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancelVideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/coin": {
        "post": {
          "tags": ["Video"],
          "summary": "投币",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/create/comment": {
        "post": {
          "tags": ["Comment"],
          "summary": "创建评论",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateCommentRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/delete/comment": {
        "post": {
          "tags": ["Comment"],
          "summary": "删除评论",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancelVideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/comment/list": {
        "get": {
          "tags": ["Comment"],
          "summary": "评论列表",
          "parameters": [
            {
              "name": "videoId",
              "in": "query",
              "required": true,
              "schema": { "type": "integer", "format": "int64" },
              "example": 2043382974715662336
            }
          ],
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/api/video/triple/action": {
        "post": {
          "tags": ["Video"],
          "summary": "三连",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VideoActionRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/user/follow": {
        "post": {
          "tags": ["Follow"],
          "summary": "关注",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FollowRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/user/chanel/follow": {
        "post": {
          "tags": ["Follow"],
          "summary": "取消关注",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FollowRequest" }
              }
            }
          },
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/user/following/list": {
        "get": {
          "tags": ["Follow"],
          "summary": "关注列表",
          "parameters": [
            {
              "name": "userId",
              "in": "query",
              "required": true,
              "schema": { "type": "integer", "format": "int64" },
              "example": 2042135742137569280
            }
          ],
          "responses": { "200": { "description": "OK" } }
        }
      },
      "/user/followers/list": {
        "get": {
          "tags": ["Follow"],
          "summary": "粉丝列表",
          "parameters": [
            {
              "name": "userId",
              "in": "query",
              "required": true,
              "schema": { "type": "integer", "format": "int64" },
              "example": 2044049530885570560
            }
          ],
          "responses": { "200": { "description": "OK" } }
        }
      }
    }
  }