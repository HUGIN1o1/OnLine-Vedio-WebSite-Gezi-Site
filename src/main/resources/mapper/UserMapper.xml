<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gezicoding.geligeli.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.gezicoding.geligeli.model.entity.User">
        <id column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="phone" property="phone" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="password" property="password" jdbcType="VARCHAR"/>
        <result column="nickname" property="nickname" jdbcType="VARCHAR"/>
        <result column="avatar" property="avatar" jdbcType="VARCHAR"/>
        <result column="gender" property="gender" jdbcType="INTEGER"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="state" property="state" jdbcType="VARCHAR"/>
        <result column="role" property="role" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_delete" property="isDelete" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        user_id, phone, email, password, nickname, avatar, gender, description, state, role,
        create_time, update_time, is_delete
    </sql>

    <select id="getUserInfo" resultType="com.gezicoding.geligeli.model.vo.user.LoginResponse">
        SELECT u.user_id,
               u.phone,
               u.nickname,
               u.avatar,
               u.gender,
               u.description,
               us.followers,
               us.video_count,
               us.following
        FROM user u
                 LEFT JOIN user_stats us ON u.user_id = us.user_id
        WHERE u.is_delete = 0
          AND u.user_id = #{userId}
    </select>

</mapper>
