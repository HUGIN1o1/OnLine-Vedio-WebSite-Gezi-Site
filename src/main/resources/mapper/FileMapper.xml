    <resultMap id="BaseResultMap" type="com.gezicoding.geligeli.model.entity.File">
        <id column="file_id" property="fileId" jdbcType="BIGINT"/>
        <result column="file_hash" property="fileHash" jdbcType="VARCHAR"/>
        <result column="file_url" property="fileUrl" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="is_delete" property="isDelete" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        file_id, file_hash, file_url, create_time, update_time, is_delete
    </sql>

</mapper>
